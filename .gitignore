# Output data files (distributed via GitHub Releases, not committed)
*.csv
*.parquet

# Vendored reference data for the finding chart (BSC5 + IAU boundaries,
# small static catalogs that ship with the dashboard).
!data/finding_chart/*.csv

# Downloaded MPC catalog files
sandbox/*.txt

# Python
__pycache__/
*.pyc
venv/

# Temporary files
*.tmp
*.bak

# OS files
.DS_Store
Thumbs.db

